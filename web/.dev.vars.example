# Local development env for `next dev` and `wrangler dev`.
# Copy to `.dev.vars` (gitignored) and fill in.
#
# Production secrets are set via:  npx wrangler secret put <NAME>

# --- Public (also in wrangler.jsonc vars; duplicated here for next dev) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_ZHluYW1pYy1nbmF0LTU2LmNsZXJrLmFjY291bnRzLmRldiQ
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/learn
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/learn

# --- Secrets (DO NOT commit your filled-in .dev.vars) ---
CLERK_SECRET_KEY=
ANTHROPIC_API_KEY=
RESEND_API_KEY=
TAVILY_API_KEY=
CF_STREAM_API_TOKEN=
# (No OpenAI key needed — voice-over runs on Cloudflare Workers AI
#  via @cf/myshell-ai/melotts, free with the Workers Paid Plan.)

# Token to call POST /api/admin/reindex (MVP-only admin gate).
# Generate locally with: openssl rand -hex 16
REINDEX_TOKEN=
