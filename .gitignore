# Partner-provided source files — do not commit
Products/
# …but the public product-directory ROUTE lives at this lowercase path; the
# filesystem is case-insensitive so the rule above would otherwise hide it.
!web/src/app/products/
!web/src/app/products/**

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Node / Next.js
node_modules/
.next/
.open-next/
.wrangler/
.dev.vars
.dev.vars.local
.env
# Catch-all for any local secret holders the dev may create
sec.env
secrets.env
*.secrets
.envrc
.env.local
.env*.local
out/
dist/
build/

# Python (seed extractors)
__pycache__/
*.pyc
.venv/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Cloudflare
.mf/
wrangler.local.toml

# Brand source files (raw exports, kept locally only — variants in web/public/brand/ are the canonical web assets)
Logos/
# Stray screenshots from chat / WeChat
微信图片*.png


# Dev artifacts — not part of the app
.claude/
.agents/
designs/
skills-lock.json
